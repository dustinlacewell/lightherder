{
  "name": "@ldlework/crt",
  "version": "0.0.1",
  "description": "Physically-grounded CRT phosphor display renderer for WebGL2 \u2014 beam-deposit accumulator, stretched-exponential persistence, halation, tonemap. Optional React surface at ./react.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/gen-shaders.mjs && tsc",
    "typecheck": "node scripts/gen-shaders.mjs && tsc --noEmit",
    "test": "node scripts/gen-shaders.mjs && vitest run",
    "test:watch": "node scripts/gen-shaders.mjs && vitest",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@ldlework/gl": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.0"
  }
}
