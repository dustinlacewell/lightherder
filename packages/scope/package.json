{
  "name": "@ldlework/scope",
  "version": "0.0.1",
  "description": "Oscilloscope signal modeling \u2014 waves, sweeps, bursts. Plain TypeScript; pair with @ldlework/crt for rendering.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/gen-shaders.mjs && tsc",
    "typecheck": "node scripts/gen-shaders.mjs && tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@ldlework/crt": "workspace:*",
    "@ldlework/gl": "workspace:*"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
